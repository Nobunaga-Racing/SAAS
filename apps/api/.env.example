PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas_gestion?schema=public
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
